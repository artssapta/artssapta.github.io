---
const { videoUrl, title } = Astro.props;
// Simple helper to extract ID from youtube URL
const videoId = videoUrl.includes('v=') ? videoUrl.split('v=')[1].split('&')[0] : videoUrl.split('/').pop();
---
<div class="video-container">
    {title && <h3>{title}</h3>}
    <iframe 
        src={`https://www.youtube.com/embed/${videoId}`} 
        title="YouTube video player" 
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
        allowfullscreen>
    </iframe>
</div>

<style>
    .video-container { max-width: 800px; margin: 40px auto; padding: 20px; }
    h3 { margin-bottom: 15px; font-family: 'Playfair Display', serif; }
    iframe { width: 100%; aspect-ratio: 16 / 9; border: none; border-radius: 8px; }
</style>
