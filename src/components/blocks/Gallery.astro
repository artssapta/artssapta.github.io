---
const { images, title } = Astro.props;
---
<div class="gallery">
    {title && <h2 class="section-title">{title}</h2>}
    <div class="grid">
        {images.map((img) => (
            <div class="gallery-item">
                <img src={img.src} alt={img.alt || "Gallery image"} />
            </div>
        ))}
    </div>
</div>

<style>
    .gallery { max-width: 1100px; margin: 40px auto; padding: 20px; }
    .section-title { font-family: 'Lora', serif; text-align: center; margin-bottom: 20px; color: #2A7396; }
    .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 15px; }
    .gallery-item img { width: 100%; height: 250px; object-fit: cover; border-radius: 4px; }
</style>
