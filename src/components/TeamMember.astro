---
const { name, role, description, image } = Astro.props;
---
<div class="team-row">
    <div class="team-img"><img src={image}></div>
    <div class="team-info">
        <h3>{name}</h3>
        <p>{description}</p>
    </div>
</div>

<style>
    .team-row { 
        display: grid; 
        grid-template-columns: 350px 1fr; 
        gap: 40px; 
        align-items: center; 
        margin-bottom: 50px; 
        border-top: 1px dashed #ccc; 
        padding-top: 40px; 
    }
    .team-img img { 
        width: 100%; 
        border-radius: 2px; 
        box-shadow: 2px 2px 10px rgba(0,0,0,0.1); 
    }
    .team-info h3 { 
        font-family: 'Lora', serif; 
        font-size: 1.8rem; 
        color: #6091B0; 
        margin-bottom: 10px; 
    }
</style>
