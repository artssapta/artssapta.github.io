---
const { title, flyerImage, color = "#2A7396" } = Astro.props;
---
<section class="events-section">
    <div class="hero-small" style={`background-color: ${color};`}>
        <h1>{title}</h1>
    </div>
    <div class="container">
        <h2 class="section-title">Latest Flyer</h2>
        <div class="flyer-container">
            <img src={flyerImage} alt="Event Flyer" />
        </div>
    </div>
</section>

<style>
    .hero-small { 
        height: 200px; 
        display: flex; 
        justify-content: center; 
        align-items: center; 
        color: white; 
        margin-bottom: 40px; 
    }
    .hero-small h1 { font-family: 'Playfair Display', serif; font-size: 3rem; }
    .container { max-width: 1100px; margin: 0 auto; padding: 0 20px; }
    .section-title { 
        font-family: 'Lora', serif; 
        font-size: 2rem; 
        color: #2A7396; 
        text-align: center; 
        margin-bottom: 30px; 
    }
    .flyer-container { text-align: center; }
    .flyer-container img { max-width: 100%; border: 1px solid #ccc; border-radius: 4px; }
</style>
